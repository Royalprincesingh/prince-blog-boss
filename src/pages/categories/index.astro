---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Hash } from 'lucide-astro';

const posts = await getCollection('blog');
const tags = [...new Set(posts.flatMap(post => post.data.tags || []))];

const categories = [
	{ name: 'Web Development', slug: 'web-development', count: posts.filter(p => (p.data.tags || []).includes('Web Development')).length },
	{ name: 'MERN Stack', slug: 'mern-stack', count: posts.filter(p => (p.data.tags || []).includes('MERN Stack')).length },
	{ name: 'JavaScript', slug: 'javascript', count: posts.filter(p => (p.data.tags || []).includes('JavaScript')).length },
	{ name: 'AI Tools', slug: 'ai-tools', count: posts.filter(p => (p.data.tags || []).includes('AI Tools')).length },
];

const title = "Categories";
const description = "Browse blog posts by category and technology.";
---

<BaseLayout title={title} description={description}>
	<section class="categories-header">
		<h1>Browse by <span class="text-accent">Category</span></h1>
		<p>Discover articles grouped by topic and expertise.</p>
	</section>

	<div class="category-grid">
		{categories.map((cat) => (
			<a href={`/categories/${cat.slug}`} class="category-card">
				<div class="icon-box"><Hash size={24} /></div>
				<h3>{cat.name}</h3>
				<p>{cat.count} articles</p>
			</a>
		))}
	</div>

	<section class="all-tags">
		<h2>All Tags</h2>
		<div class="tag-cloud">
			{tags.map(tag => (
				<a href={`/categories/${tag.toLowerCase().replace(' ', '-')}`} class="tag-item">
					{tag}
				</a>
			))}
		</div>
	</section>
</BaseLayout>

<style>
	.categories-header {
		text-align: center;
		margin-bottom: 60px;
	}

	.text-accent {
		color: var(--accent);
	}

	.category-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 32px;
		margin-bottom: 80px;
	}

	.category-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		padding: 40px;
		border-radius: 20px;
		text-align: center;
		transition: all 0.3s ease;
	}

	.category-card:hover {
		border-color: var(--accent);
		transform: translateY(-4px);
		background: var(--bg-hover);
	}

	.icon-box {
		width: 64px;
		height: 64px;
		background: var(--accent-muted);
		color: var(--accent);
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0 auto 24px;
	}

	.category-card h3 {
		margin-bottom: 8px;
	}

	.category-card p {
		color: var(--text-muted);
		font-size: 0.9rem;
	}

	.all-tags {
		border-top: 1px solid var(--border);
		padding-top: 60px;
	}

	.all-tags h2 {
		margin-bottom: 32px;
	}

	.tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
	}

	.tag-item {
		background: var(--bg-card);
		border: 1px solid var(--border);
		padding: 8px 16px;
		border-radius: 8px;
		font-size: 0.9rem;
		transition: all 0.2s ease;
	}

	.tag-item:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
</style>
